DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"

h () {
    # if arguments, print them
    [ $# == 0 ] || echo "$*"

  cat <<EOF
Usage: $(basename "${BASH_SOURCE[0]}") [OPTION]... <ipfilter.dat output location>
    generate an ipfilter.dat from a hardcoded list of sources
Available options:
  -h, --help       display this help and exit
  -c, --cache=dir  what cache dir to use, defaults to script dir/ipfilter_cache
EOF

    # if args, exit 1 else exit 0
    [ $# == 0 ] || exit 1
    exit 0
}

msg() {
    echo >&2 -e "${1-}"
}

die() {
    local msg=$1
    local code=${2-1} # default exit status 1
    msg "$msg"
    exit "$code"
}


# Function to download file with all checks
download_with_checks() {
    local url=${1?-must pass url}
    local output_file="${2?-must pass output filename}"
    args=()
    if [[ -f "$output_file" ]]; then
        args+=('-z' "$output_file" )
    fi
    if [[ -f "$output_file.etag" ]]; then
        args+=(--etag-compare "$output_file.etag")
    fi
    local http_code
    http_code=$(curl -s  \
        -w "%{http_code}\n" \
        --location \
        "${args[@]}" \
        -o "$output_file" \
        --remote-time \
        --etag-save "$output_file.etag" \
        "$url"
    )
    if [[ "$http_code" -lt 200 ]] || [[ 300 -le "$http_code" ]] && [[ "$http_code" -ne 304 ]]; then
        echo "bad http response: $http_code"
        rm "$output_file"
        return 1
    fi
}

# Function to download and process blocklists
download_blocklist() {
    local url=${1?-must pass url}
    local output=${2?-must pass output filename}

    if ! download_with_checks "$url" "$DOWNLOAD_DIR/$output"; then
        msg "Failed to download $url. Skipping."
        return 0
    fi

    case "$output" in
        *.gz)
            gunzip -c "$DOWNLOAD_DIR/$output" > "$DATA_DIR/${output%.gz}"            ;;
        *.zip)
            unzip -o "$DOWNLOAD_DIR/$output" -d "$DATA_DIR/${output%.zip}"
            find "$DATA_DIR/${output%.zip}" -type f -name "*.dat" -exec cat {} + >> "$DATA_DIR/raw_blocklist.tmp"
            ;;
        *.dat|*.txt|*.netset|*.zone)
            cat "$DOWNLOAD_DIR/$output" >> "$DATA_DIR/raw_blocklist.tmp"
            ;;
        *)
            msg "Unsupported file format: $output. Skipping."
            ;;
    esac
}

# Function to write IP ranges to file
write_ip_ranges() {
    local output_file="$1"
    local temp_file="$2"

    # Write header
    {
        echo "# qBittorrent IP Filter"
        echo "# Updated: $(date -u '+%Y-%m-%d %H:%M:%S UTC')"
        echo "# Format: range start-range end, access level"
        echo "# Access level: 0 = allowed, >0 = blocked"
        echo ""

        # Convert single IPs and CIDR to ranges and write to file
        while IFS= read -r line; do
            if [[ $line =~ ^([0-9]+\.[0-9]+\.[0-9]+\.[0-9]+)(/[0-9]+)?$ ]]; then
                # Single IP or CIDR
                if [[ $line == *"/"* ]]; then
                    # CIDR notation
                    base_ip="${BASH_REMATCH[1]}"
                    cidr="${line#*/}"
                    # Convert CIDR to range
                    IFS=. read -r i1 i2 i3 i4 <<< "$base_ip"
                    ip_int=$(( (i1 << 24) + (i2 << 16) + (i3 << 8) + i4 ))
                    mask=$((0xffffffff << (32 - cidr)))
                    net_start=$((ip_int & mask))
                    net_end=$((net_start | ~mask & 0xffffffff))
                    printf "%d.%d.%d.%d-%d.%d.%d.%d,1\n" \
                        $((net_start >> 24 & 0xff)) $((net_start >> 16 & 0xff)) \
                        $((net_start >> 8 & 0xff)) $((net_start & 0xff)) \
                        $((net_end >> 24 & 0xff)) $((net_end >> 16 & 0xff)) \
                        $((net_end >> 8 & 0xff)) $((net_end & 0xff))
                else
                    # Single IP
                    echo "${line}-${line},1"
                fi
            elif [[ $line =~ ^([0-9]+\.[0-9]+\.[0-9]+\.[0-9]+)-([0-9]+\.[0-9]+\.[0-9]+\.[0-9]+)$ ]]; then
                # Already in range format
                echo "${line},1"
            fi
        done < "$temp_file"
    } > "$output_file"
}

# Function to process a file and extract IPs
process_file() {
    local file="$1"
    local temp_file="$2"

    # Handle different file formats
    if [[ "$file" == *.gz ]]; then
        zcat "$file" | grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}(/[0-9]{1,2})?(-([0-9]{1,3}\.){3}[0-9]{1,3})?' >> "$temp_file"
    elif [[ "$file" == *.zip ]]; then
        if [[ -f "blocklist_emule/guarding.p2p" ]]; then
            grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}(/[0-9]{1,2})?(-([0-9]{1,3}\.){3}[0-9]{1,3})?' "blocklist_emule/guarding.p2p" >> "$temp_file"
        fi
    else
        grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}(/[0-9]{1,2})?(-([0-9]{1,3}\.){3}[0-9]{1,3})?' "$file" >> "$temp_file"
    fi
}

# Function to process blocklists
process_blocklists() {
    local temp_file
    local files_dir="$1"
    local output_file="$2"

    msg "Starting blocklist processing..."

    # Create temp file
    temp_file=$(mktemp)
    msg "Created temp file: $temp_file"

    # Process files
    msg "Processing downloaded files..."
    local files=()
    readarray -d '' files < <(find "$files_dir" -maxdepth 1 -type f -name "blocklist_*" -print0)
    local file_count
    file_count=${#files[@]}
    msg "Found $file_count files to process"

    local count=0
    for file in "${files[@]}"; do
        count=$((count + 1))
        msg "[$count/$file_count] Processing $(basename "$file")"

        msg ">>> Processing $(basename "$file")..."
        process_file "$file" "$temp_file"
        msg "<<< Done with $(basename "$file")"

        # Show progress every 5 files
        if ((count % 5 == 0)); then
            current_count=$(wc -l < "$temp_file")
            msg "Progress: $count/$file_count files done"
            msg "Current IP count: $current_count"
        fi
    done

    msg "Starting deduplication..."
    local total_count
    total_count=$(wc -l < "$temp_file")
    msg "Total IPs found: $total_count"

    # Create output directory if it doesn't exist
    mkdir -p "$files_dir"

    # Only sort and remove duplicates
    sort -u "$temp_file" > "$temp_file.sorted"
    mv "$temp_file.sorted" "$temp_file"

    local final_count
    final_count=$(wc -l < "$temp_file")
    local duplicate_count=$((total_count - final_count))

    msg "Summary:"
    msg "- Original IP count: $total_count"
    msg "- Duplicate IPs removed: $duplicate_count"
    msg "- Final unique IPs: $final_count"

    # Write the final file in qBittorrent format
    write_ip_ranges "$output_file" "$temp_file"

    msg "Blocklists have been updated and combined into $output_file."
    msg "The file contains $final_count IP ranges."

    # Cleanup
    rm -f "$temp_file"
}

